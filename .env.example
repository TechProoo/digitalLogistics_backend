# ─── Admin credentials ────────────────────────────────────────────────
# The admin email address (case-insensitive comparison at login time).
ADMIN_EMAIL=admin@digitaldelivery.org

# bcrypt hash of the admin password (cost factor >= 10 recommended).
# Generate with Node.js:
#   node -e "const b=require('bcrypt');b.hash('YourStrongPassword',12).then(console.log)"
# Or any bcrypt tool. NEVER put the plaintext password here.
ADMIN_PASSWORD_HASH=$2b$12$REPLACE_ME_WITH_REAL_BCRYPT_HASH

# Role embedded in the admin JWT (default: admin).
ADMIN_ROLE=admin

# Secret used to sign/verify admin JWTs.
# Must be different from JWT_SECRET used for customer tokens.
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# How long admin sessions last (default: 8h). Supports ms, s, m, h, d.
ADMIN_JWT_EXPIRES_IN=8h

# ─── Customer auth ────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d

# ─── Email (Resend) ───────────────────────────────────────────────────
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX
RESEND_FROM_EMAIL=noreply@digitaldelivery.org
RESEND_FROM_NAME=Digital Delivery
RESEND_REPLY_TO=support@digitaldelivery.org

# ─── App URLs ────────────────────────────────────────────────────────
FRONTEND_URL=https://digitaldelivery.org
BACKEND_PUBLIC_URL=https://api.digitaldelivery.org

# ─── WhatsApp Business Cloud API ─────────────────────────────────────
# Required to send WhatsApp notifications to drivers on application submission.
# From number: 0813 569 9955
# Get these from Meta Business Suite → WhatsApp → API Setup.
WHATSAPP_API_TOKEN=EAXXXXXXXXXXXXXXXXXX
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_FROM_DISPLAY=0813 569 9955

# ─── Cloudflare R2 (S3-compatible object storage) ────────────────────
# Used for driver-application file uploads (presigned PUT from browser).
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET=digitaldelivery
# Optional: public custom-domain URL for the bucket.
# When set, download links use this URL instead of presigned S3 URLs.
# R2_PUBLIC_URL=https://cdn.digitaldelivery.org

# ─── Database ────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/digitaldelivery

# ─── Server ──────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
